{
  "manifest_version": 3,
  "name": "DTF Queue New Tab",
  "version": "0.3.0",
  "description": "Shows a manual one-card queue of DTF news on the new tab page.",
  "key": "",
  "permissions": ["storage", "favicon"],
  "host_permissions": ["https://api.dtf.ru/*"],
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  }
}
